<Window x:Class="EasySave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasySave.ViewModel"
        Title="EasySave 3.0" Height="780" MinHeight="650" Width="1250" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117" Foreground="#c9d1d9"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <vm:SaveViewModel x:Key="SaveVM" ServerUrl="http://localhost:8080/api/logs" />
        <vm:LanguageViewModel x:Key="LangVM" />
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="BgBase"        Color="#0d1117"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#161b22"/>
        <SolidColorBrush x:Key="BgRaised"      Color="#21262d"/>
        <SolidColorBrush x:Key="BgInput"       Color="#010409"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#30363d"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#e6edf3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7d8590"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#238636"/>
        <SolidColorBrush x:Key="AccentGreenHi" Color="#2ea043"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#1f6feb"/>
        <SolidColorBrush x:Key="AccentYellow"  Color="#d29922"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#f85149"/>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#30363d" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="CaretBrush"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <Grid>
                                <TextBlock x:Name="PlaceholderText" Text="{TemplateBinding Tag}" Foreground="#484f58" Margin="13,9" IsHitTestVisible="False" Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" Background="Transparent"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#484f58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="Root" Background="#010409" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="1" x:Name="Arrow" Data="M 0 0 L 5 5 L 10 0" Stroke="#7d8590" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root"  Property="BorderBrush" Value="#484f58"/>
                    <Setter TargetName="Arrow" Property="Stroke"      Value="#c9d1d9"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Root"  Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                    <Setter TargetName="Root"  Property="Background"  Value="#0d1117"/>
                    <Setter TargetName="Arrow" Property="Data"        Value="M 0 5 L 5 0 L 10 5"/>
                    <Setter TargetName="Arrow" Property="Stroke"      Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#010409"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False"/>
                            <ContentPresenter x:Name="ContentSite" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" IsHitTestVisible="False" Margin="13,0,34,0" VerticalAlignment="Center" TextElement.Foreground="{StaticResource TextPrimary}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200" Background="#161b22" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="16" ShadowDepth="4" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="13,10"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#21262d"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1f3a5f"/>
                                <Setter Property="Foreground" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BgRaised}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="28,0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"  Value="#30363d"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#484f58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#21262d"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="{StaticResource AccentGreen}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGreenHi}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#2ea043"/>
                    <Setter Property="BorderBrush" Value="#3fb950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1a6626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground"  Value="{StaticResource AccentRed}"/>
            <Setter Property="BorderBrush" Value="#3d2020"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#2d1515"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#21262d"/>
            <Setter Property="Foreground"      Value="#c9d1d9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#30363d"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161b22"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadioFlat" TargetType="RadioButton">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"  Value="{StaticResource BgRaised}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Padding"     Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background"  Value="#1f3a5f"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="#58a6ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#30363d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="BorderBrush"     Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Border"
                                    Width="18" Height="18"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 2 5.5 L 4.5 8 L 9 2.5"
                                      Stroke="#ffffff"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border"    Property="Background"  Value="#1f6feb"/>
                                <Setter TargetName="Border"    Property="BorderBrush" Value="#1f6feb"/>
                                <Setter TargetName="CheckMark" Property="Visibility"  Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="#161b22"/>
            <Setter Property="AlternatingRowBackground" Value="#0d1117"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#21262d"/>
            <Setter Property="ColumnHeaderHeight"       Value="44"/>
            <Setter Property="RowHeight"                Value="44"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#0d1117"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="15,0"/>
            <Setter Property="BorderBrush"     Value="#21262d"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#21262d"
                        BorderThickness="0,0,0,1">
                            <SelectiveScrollingGrid>
                                <DataGridCellsPresenter x:Name="PART_DataGridCellsPresenter"
                                                SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                                SnapsToDevicePixels="{Binding SnapsToDevicePixels, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>
                            </SelectiveScrollingGrid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1c2128"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Height"     Value="1"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#21262d" CornerRadius="4" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" Background="{StaticResource AccentGreen}" CornerRadius="4" HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28" DataContext="{StaticResource SaveVM}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#161b22" BorderBrush="#21262d" BorderThickness="1" CornerRadius="10" Margin="0,0,24,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">

                    <TextBlock Text="Language / Langue" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Source={StaticResource LangVM}, Path=CurrentLanguage, Mode=TwoWay}" Margin="0,0,0,20">
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Français" Tag="fr"/>
                    </ComboBox>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_username]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[create_title]}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <Border Background="#2d1515" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,12" Visibility="{Binding IsBannerErrorVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="[!] " Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding BannerErrorText}" Foreground="#ffa198" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                            <Button Grid.Column="2" Command="{Binding CloseBannersCommand}" Width="24" Height="24" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" VerticalAlignment="Center">
                                <Path Data="M 6 6 L 18 18 M 18 6 L 6 18" Stroke="{StaticResource AccentRed}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Background="#0f2a18" BorderBrush="{StaticResource AccentGreen}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,12" Visibility="{Binding IsBannerSuccessVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="[OK] " Foreground="{StaticResource AccentGreen}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding BannerSuccessText}" Foreground="#56d364" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                            <Button Grid.Column="2" Command="{Binding CloseBannersCommand}" Width="24" Height="24" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" VerticalAlignment="Center">
                                <Path Data="M 6 6 L 18 18 M 18 6 L 6 18" Stroke="{StaticResource AccentGreen}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_name]}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <TextBlock Text=" *" Foreground="{StaticResource AccentRed}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_source]}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <TextBlock Text=" *" Foreground="{StaticResource AccentRed}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox Text="{Binding InputSource, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_dest]}" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <TextBlock Text=" *" Foreground="{StaticResource AccentRed}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox Text="{Binding InputTarget, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_type]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding InputType, Mode=TwoWay}" Margin="0,0,0,24">
                        <ComboBoxItem Content="{Binding Source={StaticResource LangVM}, Path=[type_full]}" Tag="Full"/>
                        <ComboBoxItem Content="{Binding Source={StaticResource LangVM}, Path=[type_diff]}" Tag="Differential"/>
                    </ComboBox>

                    <Button Content="{Binding Source={StaticResource LangVM}, Path=[menu_create]}" Command="{Binding AddJobCommand}" IsEnabled="{Binding IsButtonsEnabled}" Style="{StaticResource BtnPrimary}" Height="44" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_settings]}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_business_soft]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding BusinessSoft, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <Border Background="#1c1a0e" BorderBrush="{StaticResource AccentYellow}" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="(!) " Foreground="{StaticResource AccentYellow}" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[hint_multiple_apps]}" Foreground="#e3b341" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_encrypted_ext]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding EncryptedExt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_priority_ext]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding PriorityExt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_max_file_size]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding MaxFileSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_logs_title]}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_log_format]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" Content="JSON" IsChecked="{Binding IsJson}" Style="{StaticResource RadioFlat}"/>
                        <RadioButton Grid.Column="2" Content="XML"  IsChecked="{Binding IsXml}"  Style="{StaticResource RadioFlat}"/>
                    </Grid>

                    <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_log_destination]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,8,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" Content="{Binding Source={StaticResource LangVM}, Path=[radio_local]}"  IsChecked="{Binding IsLogLocal}"  Style="{StaticResource RadioFlat}"/>
                        <RadioButton Grid.Column="2" Content="{Binding Source={StaticResource LangVM}, Path=[radio_server]}" IsChecked="{Binding IsLogServer}" Style="{StaticResource RadioFlat}"/>
                        <RadioButton Grid.Column="4" Content="{Binding Source={StaticResource LangVM}, Path=[radio_both]}"   IsChecked="{Binding IsLogBoth}"   Style="{StaticResource RadioFlat}"/>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[label_server_url]}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24"/>
                    </StackPanel>

                    <TextBlock Text="Logs Access" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="State Logs" Command="{Binding OpenStateLogsCommand}" Style="{StaticResource ActionBtnStyle}" Height="30" Padding="0"/>
                        <Button Grid.Column="2" Content="Daily Logs" Command="{Binding OpenDailyLogsCommand}" Style="{StaticResource ActionBtnStyle}" Height="30" Padding="0"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[list_title]}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12" Grid.Row="0"/>
            <TextBlock Text="{Binding Source={StaticResource LangVM}, Path=[hint_select_multiple]}" Foreground="{StaticResource TextSecondary}" FontStyle="Italic" FontSize="12" Margin="0,0,0,12" Grid.Row="1" VerticalAlignment="Top"/>

            <Border Grid.Row="2" BorderBrush="#21262d" BorderThickness="1" CornerRadius="10" Background="#161b22" Margin="0,0,0,16" ClipToBounds="True">
                <DataGrid ItemsSource="{Binding Jobs}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          SelectionMode="Extended"
          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource ModernCheckBox}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{Binding Source={StaticResource LangVM}, Path=[col_name]}"   Binding="{Binding Job.Name}"            Width="*"/>
                        <DataGridTextColumn Header="{Binding Source={StaticResource LangVM}, Path=[col_source]}" Binding="{Binding Job.FileSource}"      Width="*"/>
                        <DataGridTextColumn Header="{Binding Source={StaticResource LangVM}, Path=[col_target]}" Binding="{Binding Job.FileDestination}" Width="*"/>
                        <DataGridTextColumn Header="{Binding Source={StaticResource LangVM}, Path=[col_type]}"   Binding="{Binding Job.Type}"            Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <ScrollViewer Grid.Row="3" Margin="0,0,0,16" MaxHeight="250" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ActiveJobs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1c2128" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Margin="0,0,8,10" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#e6edf3"/>
                                    <TextBlock Text="{Binding Status}" Grid.Column="1" HorizontalAlignment="Right" Foreground="#58a6ff" FontWeight="SemiBold" FontSize="12"/>

                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8" Margin="0,8" Minimum="0" Maximum="100" Value="{Binding Progress}"/>

                                    <TextBlock Grid.Row="2" Text="{Binding CurrentFile}" Foreground="#7d8590" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="{Binding PlayPauseIcon}" Visibility="{Binding IsActionVisible, Converter={StaticResource BoolToVis}}" IsEnabled="{Binding IsPlayPauseEnabled}" Command="{Binding Source={StaticResource SaveVM}, Path=PlayPauseCommand}" CommandParameter="{Binding Name}" Style="{StaticResource ActionBtnStyle}" Width="32" Height="26" Margin="0,0,4,0"/>
                                        <Button Content="⏹" Visibility="{Binding IsActionVisible, Converter={StaticResource BoolToVis}}" Command="{Binding Source={StaticResource SaveVM}, Path=StopCommand}" CommandParameter="{Binding Name}" Style="{StaticResource ActionBtnStyle}" Width="32" Height="26" Foreground="{StaticResource AccentRed}" Margin="0,0,4,0"/>
                                        <Button Content="✕" Visibility="{Binding IsRemoveVisible, Converter={StaticResource BoolToVis}}" Command="{Binding Source={StaticResource SaveVM}, Path=RemoveActiveJobCommand}" CommandParameter="{Binding Name}" Style="{StaticResource ActionBtnStyle}" Width="32" Height="26" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Button Content="{Binding Source={StaticResource LangVM}, Path=[menu_delete]}"  Command="{Binding DeleteJobCommand}"  IsEnabled="{Binding IsButtonsEnabled}" Style="{StaticResource BtnDanger}"  Margin="0,0,10,0"/>
                <Button Content="{Binding Source={StaticResource LangVM}, Path=[menu_execute]}" Command="{Binding ExecuteCommand}"    IsEnabled="{Binding IsButtonsEnabled}" Margin="0,0,10,0"/>
                <Button Content="{Binding Source={StaticResource LangVM}, Path=[hint_all]}"     Command="{Binding ExecuteAllCommand}" IsEnabled="{Binding IsButtonsEnabled}" Style="{StaticResource BtnPrimary}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
