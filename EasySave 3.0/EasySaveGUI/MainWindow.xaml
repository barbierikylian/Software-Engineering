<Window x:Class="EasySaveGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EasySave 3.0" Height="780" MinHeight="650" Width="1250" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117" Foreground="#c9d1d9"
        FontFamily="Segoe UI" FontSize="14">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBase"        Color="#0d1117"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#161b22"/>
        <SolidColorBrush x:Key="BgRaised"      Color="#21262d"/>
        <SolidColorBrush x:Key="BgInput"       Color="#010409"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#30363d"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#e6edf3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7d8590"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#238636"/>
        <SolidColorBrush x:Key="AccentGreenHi" Color="#2ea043"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#1f6feb"/>
        <SolidColorBrush x:Key="AccentYellow"  Color="#d29922"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#f85149"/>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#30363d" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="CaretBrush"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#484f58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="Root" Background="#010409" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="1" x:Name="Arrow" Data="M 0 0 L 5 5 L 10 0" Stroke="#7d8590" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root"  Property="BorderBrush" Value="#484f58"/>
                    <Setter TargetName="Arrow" Property="Stroke"      Value="#c9d1d9"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Root"  Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                    <Setter TargetName="Root"  Property="Background"  Value="#0d1117"/>
                    <Setter TargetName="Arrow" Property="Data"        Value="M 0 5 L 5 0 L 10 5"/>
                    <Setter TargetName="Arrow" Property="Stroke"      Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#010409"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Height"      Value="42"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False"/>
                            <ContentPresenter x:Name="ContentSite" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" IsHitTestVisible="False" Margin="13,0,34,0" VerticalAlignment="Center" TextElement.Foreground="{StaticResource TextPrimary}"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200" Background="#161b22" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="16" ShadowDepth="4" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="13,10"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#21262d"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1f3a5f"/>
                                <Setter Property="Foreground" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BgRaised}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="28,0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"  Value="#30363d"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#484f58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#21262d"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="{StaticResource AccentGreen}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentGreenHi}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#2ea043"/>
                    <Setter Property="BorderBrush" Value="#3fb950"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1a6626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground"  Value="{StaticResource AccentRed}"/>
            <Setter Property="BorderBrush" Value="#3d2020"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#2d1515"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363d"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#161b22"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RadioFlat" TargetType="RadioButton">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"  Value="{StaticResource BgRaised}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Padding"     Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background"  Value="#1f3a5f"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="#58a6ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#30363d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="RowBackground"            Value="#161b22"/>
            <Setter Property="AlternatingRowBackground" Value="#0d1117"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#21262d"/>
            <Setter Property="ColumnHeaderHeight"       Value="44"/>
            <Setter Property="RowHeight"                Value="44"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#0d1117"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="15,0"/>
            <Setter Property="BorderBrush"     Value="#21262d"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1a2d4d"/>
                    <Setter Property="Foreground" Value="#58a6ff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1c2128"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding"         Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#58a6ff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Height"     Value="1"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#21262d" CornerRadius="4" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" Background="{StaticResource AccentGreen}" CornerRadius="4" HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#161b22" BorderBrush="#21262d" BorderThickness="1" CornerRadius="10" Margin="0,0,24,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24">
                    <ComboBox x:Name="CmbLanguage" SelectionChanged="CmbLanguage_SelectionChanged" Margin="0,0,0,20">
                        <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                        <ComboBoxItem Content="Français" Tag="fr"/>
                    </ComboBox>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock x:Name="LblCreateTitle" Text="Create New Job" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <Border x:Name="BannerError" Background="#2d1515" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="[!] " Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtBannerError" Foreground="#ffa198" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                            <TextBlock x:Name="BtnCloseBannerError" Grid.Column="2" Text="✕" Foreground="{StaticResource AccentRed}" FontSize="14" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="CloseBanners_Click"/>
                        </Grid>
                    </Border>

                    <Border x:Name="BannerSuccess" Background="#0f2a18" BorderBrush="{StaticResource AccentGreen}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,12" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="[OK] " Foreground="{StaticResource AccentGreen}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="TxtBannerSuccess" Foreground="#56d364" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                            <TextBlock x:Name="BtnCloseBannerSuccess" Grid.Column="2" Text="✕" Foreground="{StaticResource AccentGreen}" FontSize="14" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="CloseBanners_Click"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="LblName" Text="Job Name" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtName" Margin="0,0,0,3"/>
                    <TextBlock x:Name="ErrName" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Consolas" Margin="2,0,0,10" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblSource" Text="Source Path" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSource" Margin="0,0,0,3"/>
                    <TextBlock x:Name="ErrSource" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Consolas" Margin="2,0,0,10" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblTarget" Text="Destination Path" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtTarget" Margin="0,0,0,3"/>
                    <TextBlock x:Name="ErrTarget" Foreground="{StaticResource AccentRed}" FontSize="11" FontFamily="Consolas" Margin="2,0,0,10" Visibility="Collapsed"/>

                    <TextBlock x:Name="LblType" Text="Backup Type" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbType" SelectedIndex="0" Margin="0,0,0,24">
                        <ComboBoxItem x:Name="CbiTypeFull" Content="Full" Tag="Full"/>
                        <ComboBoxItem x:Name="CbiTypeDiff" Content="Differential" Tag="Differential"/>
                    </ComboBox>

                    <Button x:Name="BtnAdd" Content="Create Backup Job" Click="BtnAdd_Click" Style="{StaticResource BtnPrimary}" Height="44" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock x:Name="LblSettings" Text="Settings" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                    <TextBlock x:Name="LblBusinessSoft" Text="Business Software (Blocker)" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtBusinessSoft" Text="CalculatorApp" Margin="0,0,0,8"/>

                    <Border Background="#1c1a0e" BorderBrush="{StaticResource AccentYellow}" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="(!) " Foreground="{StaticResource AccentYellow}" FontWeight="Bold" FontFamily="Consolas"/>
                            <TextBlock x:Name="LblHintMultipleApps" Text="Separate multiple apps with ;" Foreground="#e3b341" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="LblEncryptedExt" Text="Encrypted Extensions" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtEncryptedExt" Text=".txt;.pdf" Margin="0,0,0,24"/>

                    <TextBlock x:Name="LblPriorityExt" Text="Priority Extensions" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtPriorityExt" Text=".iso;.png" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,24"/>

                    <TextBlock x:Name="LblLogsTitle" Text="Log Files" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                    <TextBlock x:Name="LblLogFormat" Text="Log Format" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="RbJson" Grid.Column="0" Content="JSON" IsChecked="True" Style="{StaticResource RadioFlat}" Checked="RbLogFormat_Checked"/>
                        <RadioButton x:Name="RbXml" Grid.Column="2" Content="XML" Style="{StaticResource RadioFlat}" Checked="RbLogFormat_Checked"/>
                    </Grid>

                    <TextBlock x:Name="LblLogLocation" Text="Log Location" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                    <Border Background="#0f1f3d" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtLogPath" Grid.Column="0" Foreground="#58a6ff" FontSize="11" FontFamily="Consolas" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"></TextBlock>
                            <Border Grid.Column="1" Background="Transparent" BorderBrush="#58a6ff" BorderThickness="1" CornerRadius="5" Padding="8,4" Margin="10,0,0,0" Cursor="Hand" MouseLeftButtonUp="OpenLogsFolder_Click">
                                <TextBlock Text="..." Foreground="#58a6ff" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="LblDataLocation" Text="Data Location" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                    <Border Background="#0f1f3d" BorderBrush="{StaticResource AccentBlue}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtDataPath" Grid.Column="0" Foreground="#58a6ff" FontSize="11" FontFamily="Consolas" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="Transparent" BorderBrush="#58a6ff" BorderThickness="1" CornerRadius="5" Padding="8,4" Margin="10,0,0,0" Cursor="Hand" MouseLeftButtonUp="OpenDataFolder_Click">
                                <TextBlock Text="..." Foreground="#58a6ff" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="LblListTitle" Text="Configured Backup Jobs" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12" Grid.Row="0"/>

            <TextBlock x:Name="LblPermanentHint" Text="Use Ctrl+Click or Shift+Click to select multiple jobs." Foreground="{StaticResource TextSecondary}" FontStyle="Italic" FontSize="12" Margin="0,0,0,12" Grid.Row="1" VerticalAlignment="Top"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <Border x:Name="BannerExecError" Background="#2d1515" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,8" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="[!] " Foreground="{StaticResource AccentRed}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TxtBannerExecError" Foreground="#ffa198" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                        <TextBlock x:Name="BtnCloseBannerExecError" Grid.Column="2" Text="✕" Foreground="{StaticResource AccentRed}" FontSize="14" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="CloseBanners_Click"/>
                    </Grid>
                </Border>

                <Border x:Name="BannerExecSuccess" Background="#0f2a18" BorderBrush="{StaticResource AccentGreen}" BorderThickness="1" CornerRadius="6" Padding="12,9" Margin="0,0,0,8" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="[OK] " Foreground="{StaticResource AccentGreen}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TxtBannerExecSuccess" Foreground="#56d364" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                        <TextBlock x:Name="BtnCloseBannerExecSuccess" Grid.Column="2" Text="✕" Foreground="{StaticResource AccentGreen}" FontSize="14" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="CloseBanners_Click"/>
                    </Grid>
                </Border>

                <Border x:Name="BannerHint" Background="#1c1a0e" BorderBrush="{StaticResource AccentYellow}" BorderThickness="1" CornerRadius="6" Padding="12,9" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="(!) " Foreground="{StaticResource AccentYellow}" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="TxtBannerHint" Foreground="#e3b341" TextWrapping="Wrap" VerticalAlignment="Center" Margin="5,0,10,0"/>
                        <TextBlock x:Name="BtnCloseBannerHint" Grid.Column="2" Text="✕" Foreground="{StaticResource AccentYellow}" FontSize="14" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center" MouseLeftButtonUp="CloseBanners_Click"/>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#21262d" BorderThickness="1" CornerRadius="10" Background="#161b22" Margin="0,0,0,16" ClipToBounds="True">
                <DataGrid x:Name="GridJobs" SelectionMode="Extended" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" SelectionUnit="FullRow" SelectionChanged="GridJobs_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColName"   Header="Name"   Binding="{Binding Name}"            Width="*"/>
                        <DataGridTextColumn x:Name="ColSource" Header="Source" Binding="{Binding FileSource}"      Width="*"/>
                        <DataGridTextColumn x:Name="ColTarget" Header="Target" Binding="{Binding FileDestination}" Width="*"/>
                        <DataGridTextColumn x:Name="ColType"   Header="Type"   Binding="{Binding Type}"            Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <ScrollViewer Grid.Row="3" Margin="0,0,0,16" MaxHeight="250" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ActiveJobsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1c2128" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Margin="0,0,8,10" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#e6edf3"/>
                                    <TextBlock Text="{Binding Status}" Grid.Column="1" HorizontalAlignment="Right" Foreground="#58a6ff" FontWeight="SemiBold" FontSize="12"/>

                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8" Margin="0,8" Minimum="0" Maximum="100" Value="{Binding Progress}"/>

                                    <TextBlock Grid.Row="2" Text="{Binding CurrentFile}" Foreground="#7d8590" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="{Binding PlayPauseIcon}" IsEnabled="{Binding IsPlayPauseEnabled}" Style="{StaticResource ActionBtnStyle}" ToolTip="{Binding PlayPauseToolTip}" CommandParameter="{Binding Name}" Click="BtnPlayPause_Click" Width="32" Height="26" Margin="0,0,4,0"/>
                                        <Button Content="⏹" Style="{StaticResource ActionBtnStyle}" ToolTip="{Binding StopToolTip}" CommandParameter="{Binding Name}" Click="BtnStop_Click" Width="32" Height="26" Foreground="{StaticResource AccentRed}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="4" Orientation="Horizontal">
                <Button x:Name="BtnDelete"     Content="Delete" Click="BtnDelete_Click" Style="{StaticResource BtnDanger}" Margin="0,0,10,0"/>
                <Button x:Name="BtnExecute"    Content="Execute Selected" Click="BtnExecute_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnExecuteAll" Content="Execute All Jobs" Click="BtnExecuteAll_Click" Style="{StaticResource BtnPrimary}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>